# Configuración del servidor
NODE_ENV=development

# Seguridad - Secreto para sesiones (GENERAR UNO NUEVO EN PRODUCCIÓN)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=tu-secreto-super-seguro-cambiar-en-produccion

# API Key de Resend (obtener en https://resend.com)
RESEND_API_KEY=tu-api-key-de-resend-aqui

# Destinatarios de emails
EMAIL_TO=destinatario@gmail.com
EMAIL_TO_CC=copia@gmail.com
